# Supabase Postgres 连接串（在 Supabase 项目 Settings > Database > Connection string 中获取）
# 使用 Transaction pooler 格式：postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://..."

# Google Gemini API Key
GOOGLE_API_KEY="your-google-api-key"

# OpenAI-compatible 模型配置（默认示例为 Xiaomi MiMo Token Plan）
MODEL_API_KEY="your-model-api-key"
MODEL_BASE_URL="https://token-plan-cn.xiaomimo.com/v1"
MODEL_NAME="MiMo-V2.5"

# 允许跨域的前端域名（Vercel 部署地址）
ALLOWED_ORIGIN="https://www.lumenkb.xyz"

# 前端访问后端的地址（在 Vercel 环境变量中配置，值为 Railway 部署地址）
# VITE_API_BASE_URL="https://your-app.railway.app"
